# =============================================================================
# DrugEye Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit this file with real secrets to version control!

# =============================================================================
# DATABASE - Neon PostgreSQL
# =============================================================================
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-1.aws.neon.tech/postgres?sslmode=require"
# Direct connection for migrations (bypasses connection pooler)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-1.aws.neon.tech/postgres?sslmode=require"

# =============================================================================
# AUTHENTICATION - NextAuth.js
# =============================================================================
# You MUST generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET="YOUR_LONG_RANDOM_SECRET_MIN_32_CHARS"
# Production URL (e.g., https://drugeye.ae)
NEXTAUTH_URL="https://YOUR_PRODUCTION_DOMAIN"
# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID="YOUR_GITHUB_CLIENT_ID"
GITHUB_CLIENT_SECRET="YOUR_GITHUB_CLIENT_SECRET"

# =============================================================================
# AI SERVICES - Groq & OpenAI
# =============================================================================
# Get API key from: https://console.groq.com
GROQ_API_KEY="YOUR_GROQ_API_KEY"
# Groq model to use (default: llama-3.3-70b-versatile)
GROQ_MODEL="llama-3.3-70b-versatile"
# Optional: Get API key from: https://platform.openai.com
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# =============================================================================
# EMAIL - SMTP Configuration
# =============================================================================
# Email service provider (e.g., smtp.sendgrid.net, smtp.mailgun.org)
EMAIL_SERVER_HOST="YOUR_SMTP_HOST"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="YOUR_SMTP_USERNAME"
EMAIL_SERVER_PASSWORD="YOUR_SMTP_PASSWORD"
# Set to "true" if using SSL (port 465), "false" for TLS (port 587)
EMAIL_SERVER_SECURE="false"
# From address for emails
EMAIL_FROM="DrugEye <noreply@YOUR_DOMAIN>"

# =============================================================================
# MONITORING & ANALYTICS
# =============================================================================
# Sentry error tracking (optional but recommended)
# Create project at: https://sentry.io
SENTRY_DSN="YOUR_SENTRY_DSN"
SENTRY_AUTH_TOKEN="YOUR_SENTRY_AUTH_TOKEN"
# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID="YOUR_GA_MEASUREMENT_ID"
# Optional: Custom webhook for performance metrics
PERFORMANCE_WEBHOOK_URL=""

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Public base URL for email links
NEXT_PUBLIC_APP_URL="https://YOUR_PRODUCTION_DOMAIN"
# Node environment (set automatically by Vercel in production)
NODE_ENV="development"
# Hash salt for IP hashing
IP_HASH_SALT="YOUR_RANDOM_SALT"

# =============================================================================
# ADMIN & IMPORT
# =============================================================================
# Secret for admin data import endpoints
IMPORT_SECRET="YOUR_IMPORT_SECRET"

# =============================================================================
# PWA (Progressive Web App)
# =============================================================================
PWA_ENABLED="true"