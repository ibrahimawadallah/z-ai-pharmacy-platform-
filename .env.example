DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_ACCELERATE_API_KEY"
DIRECT_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"
NEXTAUTH_URL="https://YOUR_VERCEL_DOMAIN"
NEXTAUTH_SECRET="YOUR_LONG_RANDOM_SECRET"
NEXT_PUBLIC_APP_URL="https://YOUR_VERCEL_DOMAIN"
IP_HASH_SALT="YOUR_RANDOM_SALT"

# Ollama Configuration
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="cniongolo/biomistral:latest"
OLLAMA_TIMEOUT="120000"

# Import Secret (for admin data import endpoints)
IMPORT_SECRET="your-secret-key"

# Admin Bootstrap
# Required to enable the /api/create-admin and /api/seed-admin endpoints.
ADMIN_API_KEY="YOUR_ADMIN_API_KEY"
# Optional: override the bootstrap admin credentials (defaults shown).
ADMIN_EMAIL="admin@drugeye.com"
ADMIN_PASSWORD="Admin123456!"
ADMIN_NAME="System Administrator"

# OAuth (optional). The GitHub provider only registers when both are set.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
