    "db:generate:prod": "prisma generate --no-engine",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "postinstall": "node -e \"require('fs').rmSync('node_modules/@types/minimatch',{recursive:true,force:true})\""
