    console.log('Clearing existing drugs...')
    await prisma.drug.deleteMany({})
    
    const batchSize = 100
    let inserted = 0
    
    for (let i = 0; i < drugs.length; i += batchSize) {
      const batch = drugs.slice(i, i + batchSize)
      
