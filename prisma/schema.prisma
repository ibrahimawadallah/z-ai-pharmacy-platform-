generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "windows"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String              @id @default(cuid())
  email          String              @unique
  password       String
  name           String?
  image          String?
  role           String              @default("user")
  licenseNumber  String?
  isVerified     Boolean             @default(false)
  verifiedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  lastLoginAt    DateTime?
  accounts       Account[]
  auditLogs      AuditLog[]
  courseProgress CourseProgress[]
  favorites      Favorite[]
  patients       Patient[]
  payments       Payment[]
  ownedProjects  Project[]           @relation("ProjectOwner")
  projectMember  ProjectMember[]
  sessions       Session[]
  subscription   Subscription?
  assignedTasks  Task[]              @relation("TaskAssignee")
  createdTasks   Task[]              @relation("TaskCreator")
  searchHistory  UserSearchHistory[]

  @@index([email])
  @@index([role])
}

model Patient {
  id                  String              @id @default(cuid())
  clinicianId         String
  mrn                 String?
  firstName           String
  lastName            String
  dateOfBirth         DateTime
  gender              String
  weightKg            Float?
  heightCm            Float?
  allergies           String?
  conditions          String?
  creatinineClearance Float?
  hepaticImpairment   Boolean             @default(false)
  isPregnant          Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  clinician           User                @relation(fields: [clinicianId], references: [id], onDelete: Cascade)
  medications         PatientMedication[]

  @@index([clinicianId])
}

model PatientMedication {
  id          String    @id @default(cuid())
  patientId   String
  drugId      String
  drugName    String
  genericName String?
  dosage      String
  frequency   String
  route       String
  startDate   DateTime  @default(now())
  endDate     DateTime?
  isPRN       Boolean   @default(false)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model MohDrugAlert {
  id          String   @id @default(cuid())
  drugId      String?
  title       String
  description String
  alertType   String
  severity    String
  sourceUrl   String?
  isActive    Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([alertType])
  @@index([isActive])
}

model Subscription {
  id                    String    @id @default(cuid())
  userId                String    @unique
  planId                String
  status                String
  analyticsAccess       Boolean   @default(false)
  prioritySupport       Boolean   @default(false)
  storageLimit          Int       @default(100)
  customIntegrations    Boolean   @default(false)
  gatewayCustomerId     String?   @unique
  gatewaySubscriptionId String?   @unique
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([status])
}

model Payment {
  id            String   @id @default(cuid())
  userId        String
  amount        Float
  currency      String   @default("AED")
  status        String
  gatewayId     String?
  planId        String
  billingReason String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Drug {
  id                   String             @id @default(cuid())
  drugCode             String             @unique
  packageName          String
  genericName          String
  strength             String
  dosageForm           String
  packageSize          String?
  status               String
  dispenseMode         String?
  packagePricePublic   Float?
  packagePricePharmacy Float?
  unitPricePublic      Float?
  unitPricePharmacy    Float?
  agentName            String?
  manufacturerName     String?
  insurancePlan        String?
  govtFundedCoverage   String?
  uppScope             String?
  includedInThiqaABM   String?
  includedInBasic      String?
  includedInABM1       String?
  includedInABM7       String?
  pregnancyCategory    String?
  breastfeedingSafety  String?
  renalAdjustment      String?
  hepaticAdjustment    String?
  warnings             String?
  lastChangeDate       DateTime?
  uppEffectiveDate     DateTime?
  uppUpdatedDate       DateTime?
  uppExpiryDate        DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  g6pdSafety           String?
  offLabelUses         String?
  baseDoseIndication   String?
  baseDoseMgPerKg      Float?
  g6pdWarning          String?
  pregnancyPrecautions String?
  lastVerified         DateTime?
  source               String?
  verifiedBy           String?
  ndcCode              String?
  diseaseTreatments    DiseaseTreatment[]
  interactions         DrugInteraction[]
  sideEffects          DrugSideEffect[]
  icd10Codes           ICD10Mapping[]

  @@index([genericName])
  @@index([packageName])
  @@index([status])
  @@index([dosageForm])
  @@index([pregnancyCategory])
  @@index([status, dosageForm])
  @@index([manufacturerName])
  @@index([includedInABM7])
  @@index([renalAdjustment])
  @@index([hepaticAdjustment])
  @@index([ndcCode])
}

model ICD10Mapping {
  id              String    @id @default(cuid())
  drugId          String
  icd10Code       String
  description     String?
  category        String?
  createdAt       DateTime  @default(now())
  confidence      String?   @default("LOW")
  evidenceLevel   String?   @default("THERAPEUTIC_INFERENCE")
  isValidated     Boolean?  @default(false)
  lastVerified    DateTime?
  requiresReview  Boolean   @default(true)
  source          String?   @default("THERAPEUTIC_INFERENCE")
  updatedAt       DateTime?
  validatedBy     String?
  validationDate  DateTime?
  validationNotes String?
  verifiedBy      String?
  ndcCode         String?
  splSetId        String?
  drug            Drug      @relation(fields: [drugId], references: [id])

  @@index([drugId])
  @@index([icd10Code])
  @@index([category])
  @@index([icd10Code, category])
  @@index([source])
  @@index([confidence])
  @@index([evidenceLevel])
  @@index([isValidated])
  @@index([requiresReview])
  @@index([ndcCode])
  @@index([splSetId])
}

model DrugInteraction {
  id                String    @id @default(cuid())
  drugId            String
  secondaryDrugName String?
  secondaryDrugId   String?
  severity          String?
  interactionType   String?
  description       String?
  management        String?
  evidence          String?
  createdAt         DateTime  @default(now())
  mechanism         String?
  source            String?
  lastVerified      DateTime?
  drug              Drug      @relation(fields: [drugId], references: [id])

  @@index([drugId])
  @@index([severity])
  @@index([secondaryDrugId])
  @@index([drugId, severity])
  @@index([secondaryDrugName])
}

model DrugSideEffect {
  id           String    @id @default(cuid())
  drugId       String
  sideEffect   String
  frequency    String?
  severity     String?
  mechanism    String?
  createdAt    DateTime  @default(now())
  lastVerified DateTime?
  source       String?
  drug         Drug      @relation(fields: [drugId], references: [id])

  @@index([drugId])
  @@index([severity])
  @@index([frequency])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  drugCode  String
  drugName  String
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, drugCode])
  @@index([userId])
  @@index([drugCode])
}

model CourseProgress {
  id           String    @id @default(cuid())
  userId       String
  courseId     String
  lessonId     String
  completed    Boolean   @default(false)
  completedAt  DateTime?
  quizScore    Int?
  quizAttempts Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  course       Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, lessonId])
  @@index([userId])
  @@index([courseId])
}

model UserSearchHistory {
  id          String   @id @default(cuid())
  userId      String
  query       String
  searchType  String
  resultCount Int
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String?
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model RateLimit {
  id          String   @id @default(cuid())
  identifier  String
  endpoint    String
  requests    Int      @default(1)
  windowStart DateTime @default(now())

  @@unique([identifier, endpoint], name: "RateLimit_identifier_endpoint_key")
  @@index([identifier])
  @@index([windowStart])
}

model Project {
  id          String          @id @default(cuid())
  name        String
  description String?
  ownerId     String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  owner       User            @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     ProjectMember[]
  tasks       Task[]

  @@index([ownerId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("MEMBER")
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model Task {
  id          String           @id @default(cuid())
  title       String
  description String?
  status      String           @default("TODO")
  priority    String           @default("MEDIUM")
  dueDate     DateTime?
  projectId   String
  assigneeId  String?
  creatorId   String
  parentId    String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  assignee    User?            @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator     User             @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  parent      Task?            @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks    Task[]           @relation("SubTasks")
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  blocks      TaskDependency[] @relation("BlockingTask")
  dependsOn   TaskDependency[] @relation("DependentTask")
  tags        TaskTag[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([creatorId])
  @@index([status])
  @@index([parentId])
}

model TaskDependency {
  id          String   @id @default(cuid())
  dependentId String
  blockingId  String
  createdAt   DateTime @default(now())
  blocking    Task     @relation("BlockingTask", fields: [blockingId], references: [id], onDelete: Cascade)
  dependent   Task     @relation("DependentTask", fields: [dependentId], references: [id], onDelete: Cascade)

  @@unique([dependentId, blockingId])
  @@index([blockingId])
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  color     String    @default("blue")
  createdAt DateTime  @default(now())
  tasks     TaskTag[]
}

model TaskTag {
  id        String   @id @default(cuid())
  taskId    String
  tagId     String
  createdAt DateTime @default(now())
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, tagId])
  @@index([tagId])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventType String
  category  String?
  data      String?
  sessionId String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([createdAt])
}

model SystemError {
  id         String    @id @default(cuid())
  errorType  String
  message    String
  stack      String?
  context    String?
  resolved   Boolean   @default(false)
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([errorType])
  @@index([resolved])
  @@index([createdAt])
}

model Course {
  id                 String             @id @default(cuid())
  title              String
  titleAr            String?
  shortTitle         String?
  description        String?
  icon               String?
  color              String?
  category           String
  level              String             @default("intermediate")
  duration           String?
  creditHours        Int                @default(6)
  learningObjectives String?
  targetAudience     String?
  prerequisites      String?
  caseStudies        String?
  isPublished        Boolean            @default(false)
  isAIGenerated      Boolean            @default(false)
  createdBy          String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  assessments        CourseAssessment[]
  modules            CourseModule[]
  progress           CourseProgress[]
  resources          CourseResource[]

  @@index([category])
  @@index([level])
  @@index([isPublished])
}

model CourseModule {
  id               String   @id @default(cuid())
  courseId         String
  moduleNumber     Int
  title            String
  titleAr          String?
  icon             String?
  color            String?
  writtenContent   String?
  undergraduate    String?
  postgraduate     String?
  videos           String?
  diagrams         String?
  content          String?
  contentAr        String?
  learningOutcomes String?
  keyPoints        String?
  drugReferences   String?
  caseStudies      String?
  estimatedMinutes Int      @default(45)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  course           Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, moduleNumber])
  @@index([courseId])
}

model CourseAssessment {
  id           String               @id @default(cuid())
  courseId     String
  type         String
  moduleId     String?
  title        String
  instructions String?
  timeLimit    Int?
  passingScore Int                  @default(70)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  questions    AssessmentQuestion[]
  course       Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([type])
}

model AssessmentQuestion {
  id            String           @id @default(cuid())
  assessmentId  String
  question      String
  questionAr    String?
  type          String           @default("multiple_choice")
  options       String?
  correctAnswer String
  explanation   String?
  explanationAr String?
  points        Int              @default(1)
  createdAt     DateTime         @default(now())
  assessment    CourseAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
}

model CourseResource {
  id        String   @id @default(cuid())
  courseId  String
  type      String
  title     String
  titleAr   String?
  url       String?
  content   String?
  fileSize  Int?
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([type])
}

model Certificate {
  id                String    @id @default(cuid())
  userId            String
  courseId          String
  issueDate         DateTime  @default(now())
  expiryDate        DateTime?
  certificateNumber String    @unique
  score             Int
  verified          Boolean   @default(false)

  @@index([userId])
  @@index([courseId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

model Disease {
  id                  String             @id @default(cuid())
  name                String
  nameAr              String?
  icd10Code           String?
  category            String?
  description         String?
  symptoms            String?
  riskFactors         String?
  diagnosticCriteria  String?
  investigations      String?
  complications       String?
  prevalence          String?
  treatmentGuidelines String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  treatments          DiseaseTreatment[]

  @@index([icd10Code])
  @@index([category])
  @@index([name])
}

model DiseaseTreatment {
  id             String   @id @default(cuid())
  diseaseId      String
  drugId         String
  lineOfTherapy  String   @default("first_line")
  indication     String?
  dose           String?
  duration       String?
  notes          String?
  evidenceLevel  String?
  recommendation String?
  createdAt      DateTime @default(now())
  disease        Disease  @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  drug           Drug     @relation(fields: [drugId], references: [id], onDelete: Cascade)

  @@unique([diseaseId, drugId])
  @@index([diseaseId])
  @@index([drugId])
  @@index([lineOfTherapy])
}
